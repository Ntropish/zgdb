{
  "name": "@zgdb/cli",
  "version": "0.1.0",
  "description": "A synchronous, in-memory graph database client generated from Zod schemas.",
  "type": "module",
  "bin": {
    "zg": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "mv:interfaces": "mv src/interfaces.ts dist/interfaces.ts",
    "test": "jest",
    "zg": "node --experimental-wasm-modules dist/main.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zg",
    "zgdb",
    "graph",
    "database",
    "zod",
    "ptree",
    "flatbuffers",
    "synchronous",
    "codegen"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/jest": "^29.5.14",
    "commander": "^12.0.0",
    "cross-env": "^7.0.3",
    "flatbuffers": "^24.3.25",
    "jest": "^30.0.0",
    "lodash-es": "^4.17.21",
    "prolly-gunna": "^5.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "uuidv7": "^1.0.2",
    "zod": "^3.22.4",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.24"
  }
}
