{
  "name": "@zgdb/examples",
  "version": "0.1.0",
  "description": "A synchronous, in-memory graph database client generated from Zod schemas.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "pnpm zg:all && pnpm tsc",
    "tsc": "tsc",
    "zg:all": "concurrently \"pnpm zg:basic\" \"pnpm zg:orders\" \"pnpm zg:university\" \"pnpm zg:portfolio\"",
    "zg:basic": "zg build --config ./src/basic/schema.ts --output ./src/basic/dist/graph",
    "run:basic": "node ./dist/basic/workflow.js",
    "zg:orders": "zg build --config ./src/orders/schema.ts --output ./src/orders/dist/graph",
    "run:orders": "node ./dist/orders/workflow.js",
    "zg:university": "zg build --config ./src/university/schema.ts --output ./src/university/dist/graph",
    "run:university": "node ./dist/university/workflow.js",
    "zg:portfolio": "zg build --config ./src/portfolio/schema.ts --output ./src/portfolio/dist/graph",
    "run:portfolio": "node ./dist/portfolio/workflow.js"
  },
  "keywords": [
    "zgdb",
    "graph",
    "database",
    "zod",
    "ptree",
    "flatbuffers",
    "synchronous",
    "codegen"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^9.8.0",
    "@types/jest": "^29.5.14",
    "@zgdb/cli": "workspace:*",
    "@zgdb/runtime": "workspace:*",
    "commander": "^12.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "flatbuffers": "^24.3.25",
    "immer": "^10.1.1",
    "jest": "^30.0.0",
    "lodash-es": "^4.17.21",
    "prolly-gunna": "^5.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ulid": "^3.0.1",
    "uuidv7": "^1.0.2",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  }
}
